[
    {
        "author": "Victor Hugo",
        "text": "Gelecek, birçoklarının korktuğu ama az kişinin cesaret ettiği bir yerdir."
    },
    {
        "author": "Tolstoy",
        "text": "Herkes dünyayı değiştirmeyi düşünür, ama kimse kendini değiştirmeyi düşünmez."
    },
    {
        "author": "Aristoteles",
        "text": "Erdem, alışkanlık haline gelmiş doğru davranıştır."
    },
    {
        "author": "Descartes",
        "text": "Düşünüyorum, öyleyse varım."
    },
    {
        "author": "Voltaire",
        "text": "Özgürlük, düşüncelerini söyleyebilme cesaretidir."
    },
    {
        "author": "Goethe",
        "text": "Bildiklerinizi yapın, yapabileceklerinizle yetinmeyin."
    },
    {
        "author": "Hz. Ali",
        "text": "İlim, maldan hayırlıdır; ilim seni korur, malı ise sen korursun."
    },
    {
        "author": "Şems-i Tebrizi",
        "text": "Kusursuz dost arayan dostsuz kalır."
    },
    {
        "author": "Sabahattin Ali",
        "text": "İnsanlar birbirlerini tanıdıkça yalnızlaşırlar."
    },
    {
        "author": "Orhan Veli",
        "text": "Anlatamıyorum."
    },
    {
        "author": "Turgut Özal",
        "text": "Değişmeyen tek şey değişimin kendisidir."
    },
    {
        "author": "Albert Camus",
        "text": "Kışın ortasında, içimde yenilmez bir yaz olduğunu öğrendim."
    },
    {
        "author": "George Orwell",
        "text": "Özgürlük, iki artı iki dört eder diyebilmektir."
    },
    {
        "author": "Mark Twain",
        "text": "İlerlemek istiyorsan, başlamak zorundasın."
    },
    {
        "author": "Steve Jobs",
        "text": "Aç kalın, aptal kalın."
    },
    {
        "author": "Mustafa Kemal Atatürk",
        "text": "Hayatta en hakiki mürşit ilimdir."
    },
    {
        "author": "Mevlana",
        "text": "Ne olursan ol yine gel."
    },
    {
        "author": "Yunus Emre",
        "text": "Sevelim, sevilelim, dünya kimseye kalmaz."
    },
    {
        "author": "Nazım Hikmet",
        "text": "Yaşamak bir ağaç gibi tek ve hür ve bir orman gibi kardeşçesine."
    },
    {
        "author": "Cemil Meriç",
        "text": "Kültür, insanın kendini tanımasıdır."
    },
    {
        "author": "İbn Sina",
        "text": "Bilim ve sanat takdir edilmediği yerden göç eder."
    },
    {
        "author": "Albert Einstein",
        "text": "Hayal gücü bilgiden daha önemlidir."
    },
    {
        "author": "Sokrates",
        "text": "Sorgulanmamış hayat yaşamaya değmez."
    },
    {
        "author": "Konfüçyüs",
        "text": "Nereye gittiğini bilmiyorsan, hangi yoldan gittiğinin önemi yoktur."
    },
    {
        "author": "Nietzsche",
        "text": "Beni öldürmeyen şey güçlendirir."
    }
]